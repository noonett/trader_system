# ===== σ WebUI — LLM Provider 配置 =====
#
# 选择一个 provider，设置对应的 key 即可。

# Provider 选择（默认 anthropic）
# 可选值: anthropic / openai / ollama / openrouter / deepseek / custom
SIGMA_PROVIDER=anthropic

# 模型 ID（可选，每个 provider 有默认值）
# SIGMA_MODEL=claude-sonnet-4-20250514

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (GPT) ---
# OPENAI_API_KEY=sk-...

# --- Ollama (本地，零费用) ---
# SIGMA_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# SIGMA_MODEL=llama3.2

# --- OpenRouter (多模型网关) ---
# SIGMA_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# SIGMA_MODEL=anthropic/claude-sonnet-4

# --- DeepSeek ---
# SIGMA_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# SIGMA_MODEL=deepseek-chat

# --- 任意 OpenAI 兼容 API ---
# SIGMA_PROVIDER=custom
# CUSTOM_BASE_URL=https://your-api.example.com/v1
# CUSTOM_API_KEY=your-key
# SIGMA_MODEL=your-model

# ===== 其他配置 =====

# Workspace 路径（Docker 中默认 /data；本地开发默认自动检测）
# SIGMA_WORKSPACE=/path/to/trader_system

# 认证密码（可选，N=1 自用可不设）
# SIGMA_PASSWORD=your-secret
